{
    "name": "phpmake/phpmake",
    "description": "A PHP build automation tool using JSON configuration file.",
    "type": "library",
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "Yousha Aleayoub",
            "email": "phpmake.github@gmail.com",
            "homepage": "https://yousha.blog.ir/",
            "role": "Maintainer, Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/phpmake/phpmake/issues",
        "source": "https://github.com/phpmake/phpmake",
        "email": "phpmake.github@gmail.com"
    },
    "homepage": "https://github.com/phpmake/phpmake",
    "keywords": [
        "php",
        "make",
        "maker",
        "build",
        "builder",
        "build-automation"
    ],
    "require": {
        "php": "7.4.*",
        "ext-json": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "2.45.*",
        "friendsofphp/php-cs-fixer": "3.75.*",
        "icanhazstring/composer-unused": "0.8.*",
        "maglnet/composer-require-checker": "3.8.*",
        "overtrue/phplint": "3.4.*",
        "phpunit/phpunit": "9.6.*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "PhpMake\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpMake\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/phpmake.php"
    ],
    "archive": {
        "exclude": [
            "*.log",
            "*.cache",
            "composer.lock"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer-unused/composer-unused-plugin": true,
            "ergebnis/composer-normalize": true
        },
        "archive-format": "zip",
        "bin-compat": "full",
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": false,
        "vendor-dir": "vendor"
    },
    "extra": {
        "composer-normalize": {
            "indent-size": 4,
            "indent-style": "space"
        }
    },
    "scripts": {
        "check": "php-cs-fixer check",
        "lint": "phplint",
        "reformat": "php-cs-fixer fix",
        "test": "phpunit --configuration phpunit.xml"
    },
    "scripts-descriptions": {
        "check": "Scan codes for issues.",
        "lint": "Scan codes for syntax errors.",
        "reformat": "Reformat all codes.",
        "test": "Run all tests."
    }
}
